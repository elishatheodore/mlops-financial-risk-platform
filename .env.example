# MLOps Financial Risk Platform - Environment Variables Example
# Copy this file to .env and update with your actual values

# =============================================================================
# MLflow Configuration
# =============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=financial-risk-experiment
MLFLOW_MODEL_NAME=financial-risk-model

# =============================================================================
# Application Configuration
# =============================================================================
MODEL_NAME=financial-risk-model
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# =============================================================================
# Database Configuration (if using external database)
# =============================================================================
# DATABASE_URL=postgresql://username:password@localhost:5432/dbname
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=financial_risk
# DATABASE_USER=your_username
# DATABASE_PASSWORD=your_password

# =============================================================================
# Azure Configuration (for AKS deployment)
# =============================================================================
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_RESOURCE_GROUP=rg-mlops-risk-platform
AZURE_LOCATION=eastus
AZURE_CLUSTER_NAME=aks-risk-platform

# =============================================================================
# Container Registry Configuration
# =============================================================================
DOCKER_REGISTRY=yourregistry.azurecr.io
DOCKER_USERNAME=your_registry_username
DOCKER_PASSWORD=your_registry_password
IMAGE_TAG=latest

# =============================================================================
# Kubernetes Configuration
# =============================================================================
KUBE_CONFIG_PATH=~/.kube/config
NAMESPACE=production
SERVICE_NAME=risk-platform

# =============================================================================
# Monitoring and Observability
# =============================================================================
PROMETHEUS_URL=http://prometheus-operated.monitoring.svc.cluster.local:9090
GRAFANA_URL=http://prometheus-operator-grafana.monitoring.svc.cluster.local:3000
GRAFANA_ADMIN_PASSWORD=admin123
LOG_LEVEL=INFO

# =============================================================================
# Security Configuration
# =============================================================================
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# API Configuration
# =============================================================================
API_VERSION=v1
API_PREFIX=/api/v1
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=100
MAX_REQUEST_SIZE=10485760

# =============================================================================
# Model Configuration
# =============================================================================
MODEL_VERSION=latest
MODEL_STAGE=Production
DRIFT_THRESHOLD=0.15
DRIFT_CHECK_INTERVAL_HOURS=6
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# Feature Engineering Configuration
# =============================================================================
FEATURE_SCALING_METHOD=standard
OUTLIER_DETECTION_METHOD=iqr
OUTLIER_THRESHOLD=3.0
POLYNOMIAL_FEATURES_DEGREE=2

# =============================================================================
# Training Configuration
# =============================================================================
TRAIN_TEST_SPLIT=0.2
VALIDATION_SPLIT=0.2
RANDOM_STATE=42
CROSS_VALIDATION_FOLDS=5
HYPERPARAMETER_TUNING_ITERATIONS=50

# =============================================================================
# Performance Configuration
# =============================================================================
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CONNECTION_POOL_SIZE=10
CONNECTION_POOL_TIMEOUT=30

# =============================================================================
# Cache Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_FORMAT=json
LOG_FILE_PATH=./logs/application.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# =============================================================================
# Testing Configuration
# =============================================================================
TEST_DATABASE_URL=sqlite:///test.db
TEST_MLFLOW_TRACKING_URI=http://localhost:5001
TEST_DATA_PATH=./tests/test_data.csv

# =============================================================================
# Development Configuration
# =============================================================================
DEBUG=True
RELOAD=True
PROFILING_ENABLED=False
MOCK_EXTERNAL_APIS=True

# =============================================================================
# Production Configuration
# =============================================================================
DEBUG=False
RELOAD=False
PROFILING_ENABLED=False
MOCK_EXTERNAL_APIS=False

# =============================================================================
# Kaggle Configuration
# =============================================================================
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_API_KEY=your_kaggle_api_key

# =============================================================================
# Data Configuration
# =============================================================================
DATA_PATH=./data/creditcard.csv
RAW_DATA_PATH=./data/raw/
PROCESSED_DATA_PATH=./data/processed/
MODEL_ARTIFACTS_PATH=./mlartifacts/

# =============================================================================
# GitHub Actions Configuration
# =============================================================================
GITHUB_TOKEN=your_github_token
GITHUB_REPOSITORY=yourusername/mlops-financial-risk-platform
GITHUB_BRANCH=main

# =============================================================================
# ArgoCD Configuration
# =============================================================================
ARGOCD_SERVER_URL=https://argocd-server.argocd.svc.cluster.local
ARGOCD_USERNAME=admin
ARGOCD_PASSWORD=your_argocd_password

# =============================================================================
# Alerting Configuration
# =============================================================================
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_email_password
ALERT_RECIPIENTS=admin@yourcompany.com,devops@yourcompany.com

# =============================================================================
# Backup Configuration
# =============================================================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_ACCOUNT=your_backup_storage_account
BACKUP_CONTAINER=backups

# =============================================================================
# Compliance and Auditing
# =============================================================================
AUDIT_LOG_ENABLED=True
AUDIT_LOG_PATH=./logs/audit.log
DATA_RETENTION_DAYS=365
COMPLIANCE_MODE=strict

# =============================================================================
# Additional Notes
# =============================================================================

# Security Best Practices:
# 1. Never commit actual secrets to version control
# 2. Use strong, unique passwords
# 3. Rotate secrets regularly
# 4. Use environment-specific configurations
# 5. Enable encryption for sensitive data

# Environment-Specific Values:
# - Development: Use local services, enable debugging
# - Staging: Use production-like services, limited data
# - Production: Use production services, full monitoring

# Required for Production:
# - All secrets must be configured
# - SSL certificates must be valid
# - Monitoring must be enabled
# - Backup must be configured

# Optional for Development:
# - Mock services can be enabled
# - Debug logging can be verbose
# - Local databases can be used
