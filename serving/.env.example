# Model Configuration
MODEL_PATH=/app/model/model.pkl
MODEL_NAME=financial-risk-model
MODEL_VERSION=latest

# MLflow Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=financial-risk

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Monitoring Configuration
PROMETHEUS_ENABLED=true
METRICS_PORT=8000
LOG_LEVEL=INFO

# Security Configuration
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=*

# Database Configuration (if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/riskdb

# External Services
REDIS_URL=redis://localhost:6379
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Feature Store Configuration
FEATURE_STORE_URI=sqlite:///feature_store.db

# Model Monitoring
DRIFT_DETECTION_ENABLED=true
DRIFT_THRESHOLD=0.1
PERFORMANCE_MONITORING_ENABLED=true

# Business Logic
RISK_THRESHOLDS_LOW=20
RISK_THRESHOLDS_MEDIUM=50
RISK_THRESHOLDS_HIGH=80
MAX_LOAN_AMOUNT_RATIO=10

# Cache Configuration
CACHE_TTL=3600
CACHE_ENABLED=true
